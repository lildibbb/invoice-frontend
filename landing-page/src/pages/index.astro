---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import LogosStrip from '../components/sections/LogosStrip.astro';
import VideoShowcase from '../components/sections/VideoShowcase.astro';
import Problem from '../components/sections/Problem.astro';
import Features from '../components/sections/Features.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Stats from '../components/sections/Stats.astro';
import LhdnCompliance from '../components/sections/LhdnCompliance.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Pricing from '../components/sections/Pricing.astro';
import Faq from '../components/sections/Faq.astro';
import CtaBand from '../components/sections/CtaBand.astro';
---
<BaseLayout
  title="Invoiz — The Smartest Way to Invoice in Malaysia | LHDN e-Invoice"
  description="Generate, submit, and track e-invoices with full LHDN MyInvois compliance. Built for Malaysian businesses of all sizes. Request early access today."
  canonicalUrl="/"
>
  <Header />
  <main>
    <Hero />
    <LogosStrip />
    <VideoShowcase />
    <Problem />
    <Features />
    <HowItWorks />
    <Stats />
    <LhdnCompliance />
    <Testimonials />
    <Pricing />
    <Faq />
    <CtaBand />
  </main>
  <Footer />
</BaseLayout>
