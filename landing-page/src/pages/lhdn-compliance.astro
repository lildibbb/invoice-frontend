---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';

const phases = [
  {
    date: 'August 2024',
    title: 'Phase 1',
    description: 'Companies with annual revenue exceeding RM 100 million.',
    active: true,
  },
  {
    date: 'January 2025',
    title: 'Phase 2',
    description: 'Companies with annual revenue exceeding RM 25 million.',
    active: true,
  },
  {
    date: 'July 2025',
    title: 'Phase 3',
    description: 'All remaining businesses regardless of revenue.',
    active: false,
  },
];

const steps = [
  { icon: 'ph:pencil-simple-duotone', label: 'Create', description: 'Create your invoice in Invoiz with all required LHDN fields.' },
  { icon: 'ph:check-square-duotone', label: 'Validate', description: 'Invoiz validates your document against LHDN schema requirements.' },
  { icon: 'ph:paper-plane-tilt-duotone', label: 'Submit', description: 'We submit the e-invoice to LHDN MyInvois in real time.' },
  { icon: 'ph:seal-check-duotone', label: 'Confirm', description: 'Receive confirmation with a unique LHDN identifier and QR code.' },
];

const checklist = [
  { title: 'Tax Identification Number (TIN)', description: 'Automatically mapped from your company profile for every invoice.' },
  { title: 'MSIC & SST Registration', description: 'Stored in your settings and applied to all submissions.' },
  { title: 'Mandatory Invoice Fields', description: 'All 55+ LHDN-required fields are enforced by our invoice builder.' },
  { title: 'Digital Signature', description: 'Documents are digitally signed before submission to LHDN.' },
  { title: 'Real-Time Submission', description: 'Invoices are submitted to LHDN MyInvois within seconds of creation.' },
  { title: 'QR Code Embedding', description: 'LHDN validation QR codes are embedded in your PDF invoices automatically.' },
  { title: 'Credit & Debit Notes', description: 'Full support for corrections, refunds, and adjustments per LHDN guidelines.' },
  { title: '7-Year Audit Trail', description: 'Immutable SHA-256 hashed records retained for the full statutory period.' },
];
---
<BaseLayout title="LHDN e-Invoice Compliance — Invoiz">
  <Header />
  <main>
    <!-- Mini Hero -->
    <section class="bg-abyss pt-32 pb-20 px-4 text-center">
      <div class="inline-flex items-center gap-2 border border-brand-500/30 bg-brand-500/10 text-brand-400 text-[13px] font-medium px-4 py-1.5 rounded-full mb-8">
        <Icon name="ph:shield-check-duotone" class="w-4 h-4" />
        LHDN MyInvois
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white">100% LHDN Compliant E-Invoicing</h1>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">Everything you need to meet Malaysia's e-invoice mandate</p>
    </section>

    <!-- Timeline -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-slate-900 text-center mb-12">Malaysia e-Invoice Timeline</h2>
        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-slate-200 hidden md:block"></div>
          <div class="space-y-10">
            {phases.map((phase) => (
              <div class="relative flex items-start gap-6 md:pl-16">
                <div class={`absolute left-4 w-5 h-5 rounded-full border-4 hidden md:block ${phase.active ? 'bg-brand-500 border-brand-200' : 'bg-slate-300 border-slate-100'}`}></div>
                <div class="flex-1 bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
                  <span class={`inline-block text-xs font-semibold px-3 py-1 rounded-full mb-3 ${phase.active ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700'}`}>
                    {phase.date}
                  </span>
                  <h3 class="text-lg font-semibold text-slate-900">{phase.title}</h3>
                  <p class="mt-1 text-sm text-slate-500">{phase.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- What is e-Invoice -->
    <section class="py-16 px-4 bg-slate-50">
      <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-display text-3xl font-bold text-slate-900 mb-6">What is an e-Invoice?</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            An e-Invoice is a digital document that is validated and recorded by LHDN (Lembaga Hasil Dalam Negeri) through the MyInvois system. Unlike traditional paper or PDF invoices, an e-Invoice carries a unique identifier and QR code issued by LHDN, making it a legally recognized tax document.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Starting 2024, Malaysian businesses are required to issue e-Invoices for all B2B and B2C transactions. This is part of Malaysia's digital transformation initiative to improve tax compliance and reduce fraud.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-slate-900 mb-4">Key requirements include:</h3>
          <ul class="space-y-3">
            {[
              'Mandatory for all Malaysian businesses by mid-2025',
              'Must be submitted to LHDN in real time or near real time',
              'Requires specific data fields defined by LHDN schema',
              'Each invoice receives a unique identification number (UIN)',
              'Validated invoices include a QR code for verification',
              'Credit and debit notes must also be submitted electronically',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <Icon name="ph:check-circle-duotone" class="w-5 h-5 text-brand-500 flex-shrink-0 mt-0.5" />
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- How Invoiz Handles It -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-slate-900 text-center mb-12">How Invoiz handles it</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map((step, i) => (
            <div class="relative text-center">
              <div class="w-16 h-16 rounded-2xl bg-brand-50 flex items-center justify-center mx-auto mb-4">
                <Icon name={step.icon} class="w-8 h-8 text-brand-500" />
              </div>
              <div class="text-xs font-semibold text-brand-500 mb-1">Step {i + 1}</div>
              <h3 class="text-lg font-semibold text-slate-900">{step.label}</h3>
              <p class="mt-2 text-sm text-slate-500 leading-relaxed">{step.description}</p>
              {i < steps.length - 1 && (
                <div class="hidden lg:block absolute top-8 -right-3 text-slate-300">
                  <Icon name="ph:arrow-right-bold" class="w-5 h-5" />
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Compliance Checklist -->
    <section class="py-16 px-4 bg-slate-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-slate-900 text-center mb-12">Compliance checklist</h2>
        <div class="space-y-4">
          {checklist.map((item) => (
            <div class="flex items-start gap-4 bg-white rounded-xl border border-slate-200 p-5">
              <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <Icon name="ph:check-bold" class="w-4 h-4 text-green-600" />
              </div>
              <div>
                <h3 class="font-semibold text-slate-900">{item.title}</h3>
                <p class="mt-1 text-sm text-slate-500">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-4 bg-abyss text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display text-3xl font-bold text-white">Get compliant before the deadline</h2>
        <p class="mt-4 text-lg text-slate-400">Start your free trial today and submit your first e-invoice to LHDN in minutes.</p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="http://localhost:4200/login" class="bg-gradient-brand text-white px-8 py-4 rounded-xl font-semibold text-lg shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40 transition-all">
            Start Free Trial
          </a>
          <a href="/pricing" class="border border-slate-700 text-slate-300 px-8 py-4 rounded-xl font-semibold text-lg hover:border-slate-500 hover:text-white transition-all">
            View Pricing
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="py-12 border-t border-gray-100 text-center text-gray-400 text-sm bg-white">
    <p>&copy; 2026 Invoiz &middot; All rights reserved &middot; <a href="#" class="hover:text-blue-600 transition-colors">Privacy Policy</a> &middot; <a href="#" class="hover:text-blue-600 transition-colors">Terms</a></p>
  </footer>
</BaseLayout>
