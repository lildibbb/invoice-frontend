---
---
<section id="waitlist" class="bg-dark py-32 lg:py-40 px-4" aria-label="Join Waitlist">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="cta-reveal font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-[-0.03em]">
      Ready nak start?
    </h2>
    <p class="cta-reveal mt-4 text-lg text-white/60 max-w-md mx-auto">
      Join waitlist sekarang. Be among the first Malaysian businesses to try Invoiz.
    </p>

    <form id="waitlist-form" class="mt-10 max-w-md mx-auto" action="#" method="POST">
      <div class="flex gap-2">
        <input type="email" name="email" placeholder="Your work email" required
          class="flex-1 bg-white/5 border border-white/10 rounded-l-xl px-5 py-4 text-sm text-white placeholder-white/30 focus:border-white/25 focus:ring-1 focus:ring-white/25 focus:outline-none transition-colors" />
        <button type="submit" class="bg-white text-dark px-6 py-4 rounded-r-xl font-semibold text-sm hover:bg-white/90 active:scale-[0.98] transition-all duration-150 whitespace-nowrap">
          Join Waitlist
        </button>
      </div>
    </form>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-[13px] text-white/40">
      <span>No credit card required</span>
      <span>Invite-only access</span>
      <span>Personal onboarding</span>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.cta-reveal', {
    opacity: 0, y: 25, stagger: 0.1, duration: 0.6, ease: 'power3.out',
    scrollTrigger: { trigger: '.cta-reveal', start: 'top 85%', once: true },
  });

  const form = document.getElementById('waitlist-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    if (btn) {
      btn.textContent = 'Terima kasih!';
      btn.setAttribute('disabled', 'true');
      btn.classList.add('opacity-70');
    }
  });
</script>