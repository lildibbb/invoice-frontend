---
---
<section class="relative bg-white pt-32 lg:pt-40 pb-8 px-4 overflow-hidden" aria-label="Hero">
  <div class="relative max-w-6xl mx-auto">
    <!-- Copy: centered -->
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="font-display text-[48px] sm:text-[64px] lg:text-[88px] font-extrabold leading-[1.05] tracking-[-0.04em] text-ink">
        Invoicing yang finally make sense.
      </h1>

      <p class="hero-sub mt-6 text-lg lg:text-xl text-ink-light leading-relaxed max-w-xl mx-auto">
        Buat invoice, submit LHDN, collect payment — semua dalam satu platform. Built for Malaysian businesses yang nak kerja smart.
      </p>

      <div class="hero-cta mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="#waitlist" class="inline-flex items-center gap-2 bg-accent text-white px-8 py-4 rounded-xl font-semibold text-base hover:bg-accent-hover active:scale-[0.98] transition-all duration-150">
          Join Waitlist &rarr;
        </a>
        <a href="#video" class="inline-flex items-center gap-2 border border-border text-ink px-8 py-4 rounded-xl font-semibold text-base hover:bg-surface transition-all duration-150">
          Watch Demo
        </a>
      </div>

      <p class="hero-trust mt-6 text-sm text-ink-muted">
        No credit card &middot; Invite-only &middot; Personal onboarding
      </p>
    </div>

    <!-- 3D Product Mockup -->
    <div class="mt-20 perspective-2000" id="hero-mockup-wrapper">
      <div class="relative max-w-5xl mx-auto">
        <div class="preserve-3d rounded-2xl overflow-hidden mockup-shadow border border-border" id="hero-mockup" style="transform: perspective(2000px) rotateX(12deg) rotateY(0deg);">
          <div class="bg-white rounded-2xl overflow-hidden">
            <!-- Browser chrome -->
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border bg-surface">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-ink-muted/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-ink-muted/30"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-ink-muted/30"></div>
              </div>
              <div class="flex-1 text-center">
                <span class="text-[10px] text-ink-muted font-mono bg-white px-3 py-0.5 rounded border border-border">app.invoiz.my</span>
              </div>
            </div>
            <div class="flex min-h-[280px] lg:min-h-[380px]">
              <!-- Sidebar -->
              <div class="hidden sm:block w-40 border-r border-border bg-surface p-3">
                <div class="flex items-center gap-1.5 mb-6">
                  <div class="w-5 h-5 rounded bg-accent flex items-center justify-center">
                    <span class="text-[7px] font-bold text-white">iz</span>
                  </div>
                  <span class="text-[11px] font-bold text-ink">Invoiz</span>
                </div>
                <div class="space-y-0.5 text-[10px]">
                  <div class="px-2 py-1.5 rounded-md bg-accent/8 text-accent font-medium">Dashboard</div>
                  <div class="px-2 py-1.5 text-ink-light">Invoices</div>
                  <div class="px-2 py-1.5 text-ink-light">Customers</div>
                  <div class="px-2 py-1.5 text-ink-light">Payments</div>
                  <div class="px-2 py-1.5 text-ink-light">Reports</div>
                  <div class="px-2 py-1.5 text-ink-light">Settings</div>
                </div>
              </div>
              <!-- Main content -->
              <div class="flex-1 p-4 lg:p-5">
                <div class="flex items-center justify-between mb-4">
                  <div class="text-xs font-semibold text-ink">Dashboard</div>
                  <div class="text-[10px] text-accent font-medium bg-accent/8 px-2 py-0.5 rounded">+ New Invoice</div>
                </div>
                <div class="grid grid-cols-3 gap-3 mb-4">
                  <div class="bg-surface rounded-lg p-3 border border-border">
                    <div class="text-[8px] text-ink-muted mb-1">Revenue</div>
                    <div class="text-sm font-bold text-ink">RM 124,500</div>
                    <div class="text-[9px] text-accent mt-0.5">+12.5% this month</div>
                  </div>
                  <div class="bg-surface rounded-lg p-3 border border-border">
                    <div class="text-[8px] text-ink-muted mb-1">Outstanding</div>
                    <div class="text-sm font-bold text-ink">RM 28,200</div>
                    <div class="text-[9px] text-ink-muted mt-0.5">8 invoices pending</div>
                  </div>
                  <div class="bg-surface rounded-lg p-3 border border-border">
                    <div class="text-[8px] text-ink-muted mb-1">LHDN Submitted</div>
                    <div class="text-sm font-bold text-ink">142</div>
                    <div class="text-[9px] text-accent mt-0.5">All accepted</div>
                  </div>
                </div>
                <!-- Chart area -->
                <div class="bg-surface rounded-lg p-3 border border-border mb-4">
                  <div class="text-[8px] text-ink-muted mb-2">Monthly Revenue</div>
                  <div class="flex items-end gap-[3px] h-16 lg:h-24">
                    <div class="flex-1 rounded-sm bg-accent/20" style="height:30%"></div>
                    <div class="flex-1 rounded-sm bg-accent/20" style="height:42%"></div>
                    <div class="flex-1 rounded-sm bg-accent/20" style="height:35%"></div>
                    <div class="flex-1 rounded-sm bg-accent/20" style="height:50%"></div>
                    <div class="flex-1 rounded-sm bg-accent/25" style="height:45%"></div>
                    <div class="flex-1 rounded-sm bg-accent/25" style="height:58%"></div>
                    <div class="flex-1 rounded-sm bg-accent/30" style="height:52%"></div>
                    <div class="flex-1 rounded-sm bg-accent/30" style="height:68%"></div>
                    <div class="flex-1 rounded-sm bg-accent/35" style="height:62%"></div>
                    <div class="flex-1 rounded-sm bg-accent/40" style="height:75%"></div>
                    <div class="flex-1 rounded-sm bg-accent/50" style="height:70%"></div>
                    <div class="flex-1 rounded-sm bg-accent" style="height:88%"></div>
                  </div>
                </div>
                <!-- Invoice table -->
                <div class="bg-surface rounded-lg border border-border overflow-hidden">
                  <div class="px-3 py-2 border-b border-border flex items-center justify-between">
                    <span class="text-[9px] font-semibold text-ink">Recent Invoices</span>
                    <span class="text-[8px] text-accent">View all</span>
                  </div>
                  <div class="divide-y divide-border text-[10px]">
                    <div class="flex items-center px-3 py-2">
                      <span class="w-20 text-accent font-mono font-medium">INV-0142</span>
                      <span class="flex-1 text-ink-light hidden sm:block">TechVentures Sdn Bhd</span>
                      <span class="w-20 text-right font-medium text-ink">RM 8,500</span>
                      <span class="w-16 text-right"><span class="text-accent text-[9px] font-medium">Accepted</span></span>
                    </div>
                    <div class="flex items-center px-3 py-2">
                      <span class="w-20 text-accent font-mono font-medium">INV-0141</span>
                      <span class="flex-1 text-ink-light hidden sm:block">Nusantara Solutions</span>
                      <span class="w-20 text-right font-medium text-ink">RM 12,200</span>
                      <span class="w-16 text-right"><span class="text-ink-muted text-[9px]">Pending</span></span>
                    </div>
                    <div class="flex items-center px-3 py-2">
                      <span class="w-20 text-accent font-mono font-medium">INV-0140</span>
                      <span class="flex-1 text-ink-light hidden sm:block">KL Digital Agency</span>
                      <span class="w-20 text-right font-medium text-ink">RM 5,800</span>
                      <span class="w-16 text-right"><span class="text-accent text-[9px] font-medium">Accepted</span></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating micro-card: Invoice sent -->
        <div class="hidden lg:block absolute -right-8 top-16 animate-float" aria-hidden="true">
          <div class="bg-white border border-border rounded-xl px-4 py-3 shadow-card">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-accent/8 flex items-center justify-center">
                <svg class="w-4 h-4 text-accent" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8l3 3 5-6"/></svg>
              </div>
              <div>
                <div class="text-[10px] text-ink-muted">Invoice Sent</div>
                <div class="text-xs font-semibold text-ink">INV-0142 &middot; RM 8,500</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating micro-card: Payment received -->
        <div class="hidden lg:block absolute -left-6 bottom-24 animate-float-delayed" aria-hidden="true">
          <div class="bg-white border border-border rounded-xl px-4 py-3 shadow-card">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-accent/8 flex items-center justify-center text-xs font-bold text-accent">RM</div>
              <div>
                <div class="text-[10px] text-ink-muted">Payment Received</div>
                <div class="text-xs font-semibold text-ink">+RM 12,200.00</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('h1', { opacity: 0, y: 30, duration: 0.7 }, 0.2)
    .from('.hero-sub', { opacity: 0, y: 20, duration: 0.5 }, '-=0.4')
    .from('.hero-cta', { opacity: 0, y: 16, duration: 0.5 }, '-=0.3')
    .from('.hero-trust', { opacity: 0, duration: 0.4 }, '-=0.3')
    .from('#hero-mockup', { opacity: 0, y: 60, scale: 0.96, duration: 1.2, ease: 'expo.out' }, '-=0.6');

  const mockup = document.getElementById('hero-mockup');
  const wrapper = document.getElementById('hero-mockup-wrapper');

  // Scroll: flatten rotateX from 12deg to 0deg
  if (mockup) {
    ScrollTrigger.create({
      trigger: wrapper,
      start: 'top 80%',
      end: 'bottom 20%',
      scrub: 1,
      onUpdate: (self) => {
        const rx = 12 - (self.progress * 12);
        gsap.set(mockup, { rotateX: rx, overwrite: 'auto' });
      },
    });
  }

  // Mouse parallax
  if (mockup && wrapper && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.addEventListener('mousemove', (e) => {
      const rect = wrapper.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const ry = ((e.clientX - cx) / (rect.width / 2)) * 3;
      const rx = ((e.clientY - cy) / (rect.height / 2)) * -2;
      gsap.to(mockup, { rotateY: ry, duration: 0.8, ease: 'power2.out', overwrite: 'auto' });
    });
  }
</script>