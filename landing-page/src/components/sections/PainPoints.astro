---
const items = [
  {
    num: '01',
    title: 'Dari manual entry ke auto-fill',
    desc: 'Tak payah taip satu-satu. Customer data, tax rates, line items — semua auto-populate. Buat invoice dalam 3 minit, bukan 3 jam.',
    old: 'Copy-paste dari Excel, manual calculate tax, format lain-lain semua.',
  },
  {
    num: '02',
    title: 'Dari LHDN stress ke LHDN sorted',
    desc: 'Setiap invoice auto-validate sebelum submit. Format betul, data lengkap, terus accepted. Zero rejection.',
    old: 'Check format betul ke tak, submit manual, tunggu reply, kena reject pulak.',
  },
  {
    num: '03',
    title: 'Dari chase payment ke auto-track',
    desc: 'Real-time payment status. Automatic reminders sent. Tahu siapa dah bayar, siapa belum — tanpa follow up manual.',
    old: 'WhatsApp client satu-satu tanya "dah bayar ke belum?". Every. Single. Month.',
  },
];
---
<section class="relative py-24 lg:py-32 px-4 bg-white" aria-label="Why Invoiz">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16 lg:mb-20">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-600 mb-4 reveal-item">Kenapa Invoiz?</p>
      <h2 class="reveal-item font-display text-3xl sm:text-4xl lg:text-[48px] font-bold text-carbon leading-tight max-w-2xl">
        Invoice tak sepatutnya<br />susah macam ni.
      </h2>
    </div>

    <div class="space-y-16 lg:space-y-20">
      {items.map((item) => (
        <div class="pain-row grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 items-start">
          <div class="lg:col-span-1">
            <span class="font-display text-5xl lg:text-6xl font-extrabold text-surface-200">{item.num}</span>
          </div>
          <div class="lg:col-span-5">
            <h3 class="font-display text-xl lg:text-2xl font-bold text-carbon mb-3">{item.title}</h3>
            <p class="text-base text-graphite leading-relaxed">{item.desc}</p>
          </div>
          <div class="lg:col-span-6">
            <div class="bg-surface-50 rounded-xl p-5 lg:p-6 border border-surface-200">
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">The old way</p>
              <p class="text-sm text-graphite leading-relaxed italic">{item.old}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.reveal-item', {
    opacity: 0,
    y: 30,
    stagger: 0.1,
    duration: 0.6,
    ease: 'power3.out',
    scrollTrigger: { trigger: '.reveal-item', start: 'top 85%', once: true },
  });

  gsap.utils.toArray('.pain-row').forEach((row: any) => {
    gsap.from(row.children, {
      opacity: 0,
      y: 25,
      stagger: 0.08,
      duration: 0.6,
      ease: 'power3.out',
      scrollTrigger: { trigger: row, start: 'top 82%', once: true },
    });
  });
</script>