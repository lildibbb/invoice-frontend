---
const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Features', href: '#features' },
      { label: 'Pricing', href: '#pricing' },
      { label: 'LHDN Compliance', href: '#compliance' },
      { label: 'API', href: '#', badge: 'Soon' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Blog', href: '/blog' },
      { label: 'Careers', href: '#' },
      { label: 'Contact', href: 'mailto:hello@invoiz.my' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Documentation', href: '#' },
      { label: 'Help Center', href: '#' },
      { label: 'Status', href: '#' },
      { label: 'Changelog', href: '#' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy', href: '#' },
      { label: 'Terms', href: '#' },
      { label: 'Cookies', href: '#' },
    ],
  },
];
---
<footer class="bg-dark pt-16 pb-8 px-6 lg:px-8" role="contentinfo">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8 lg:gap-12">
      <div class="col-span-2">
        <a href="/" class="inline-flex items-center gap-2">
          <div class="w-7 h-7 rounded-md bg-accent flex items-center justify-center">
            <span class="text-[10px] font-extrabold text-white tracking-tight">iz</span>
          </div>
          <span class="font-display text-lg font-bold text-white">Invoiz</span>
        </a>
        <p class="mt-4 text-sm text-white/40 leading-relaxed max-w-xs">
          LHDN-compliant e-invoicing platform built for Malaysian businesses.
        </p>
        <div class="mt-6 flex items-center gap-4 text-sm text-white/40">
          <a href="#" class="hover:text-white transition-colors" aria-label="Twitter">X</a>
          <a href="#" class="hover:text-white transition-colors" aria-label="LinkedIn">LinkedIn</a>
        </div>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="text-xs font-semibold text-white/50 mb-4">{col.title}</h3>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-white/40 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30">&copy; 2026 Invoiz. All rights reserved.</p>
      <p class="text-xs text-white/30">Made in Malaysia 🇲🇾</p>
    </div>
  </div>
</footer>